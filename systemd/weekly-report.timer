[Unit]
Description=Run weekly report + retries (Fri/Sat 16:00-18:00 Europe/London)

[Timer]
OnCalendar=Fri *-*-* 16:00:00
OnCalendar=Fri *-*-* 17:00:00
OnCalendar=Fri *-*-* 18:00:00
OnCalendar=Sat *-*-* 16:00:00
OnCalendar=Sat *-*-* 17:00:00
OnCalendar=Sat *-*-* 18:00:00
Persistent=true
AccuracySec=1min
Unit=weekly-report.service

[Install]
WantedBy=timers.target
